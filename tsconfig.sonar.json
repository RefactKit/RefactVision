// tsconfig.sonar.json — no extends, no external deps
{
    "compilerOptions": {
        "target": "ES2022",
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "paths": {
            "~/*": [
                "./src/*"
            ],
            "#/*": [
                "./src/*"
            ],
            "@/*": [
                "./src/*"
            ]
        },
        "lib": [
            "ES2022",
            "DOM",
            "DOM.Iterable"
        ],
        "types": [
            "vite/client",
            "node"
        ],
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "**/*.ts",
        "**/*.tsx"
    ],
    "exclude": [
        "node_modules",
        ".nitro",
        ".output",
        "dist"
    ]
}